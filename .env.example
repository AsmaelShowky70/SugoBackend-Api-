# ═════════════════════════════════════════════════════════════════
# Sugo Backend — Environment Variables Configuration
# ═════════════════════════════════════════════════════════════════
# 
# تعليمات الاستخدام:
# 1. انسخ هذا الملف وأعد تسميته إلى: .env
# 2. غيّر القيم حسب بيئتك
# 3. استخدم مع docker-compose:
#    docker-compose --env-file .env up -d
#
# ⚠️ هام: لا تشارك ملف .env الحقيقي — أضفه إلى .gitignore
# ═════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────
# قاعدة البيانات (Database)
# ─────────────────────────────────────────────────────────────────

# كلمة المرور الرئيسية للـ SQL Server (SA account)
# ⚠️ يجب أن تكون قوية: 8+ حروف مع أحرف كبيرة + أرقام + رموز خاصة
DB_PASSWORD=SugoPassword123!

# اسم قاعدة البيانات (اختياري — الافتراضي: sugo_db)
# DB_NAME=sugo_db

# منفذ SQL Server (اختياري — الافتراضي: 1433)
# DB_PORT=1433

# ─────────────────────────────────────────────────────────────────
# المصادقة (JWT Authentication)
# ─────────────────────────────────────────────────────────────────

# مفتاح JWT السري — يجب أن يكون عشوائياً وقوياً جداً
# الحد الأدنى: 32 حرف
# استخدم أداة لإنشاء مفتاح عشوائي آمن
# مثال: openssl rand -base64 32 (على Linux/Mac)
# أو استخدم موقع: https://www.random.org/bytes/
JWT_KEY=aK8#mP9@xL2$vQ1%rT4&sW5!nE6^jH7*CHANGE_THIS_TO_YOUR_SECURE_KEY

# منصق JWT (Issuer)
# JWT_ISSUER=SugoBackend

# جمهور JWT (Audience)
# JWT_AUDIENCE=SugoFrontend

# مدة انتهاء الـ token بالدقائق
# JWT_EXPIRY=60

# ─────────────────────────────────────────────────────────────────
# تكوين التطبيق (Application)
# ─────────────────────────────────────────────────────────────────

# بيئة التشغيل: Development أو Production
ASPNETCORE_ENVIRONMENT=Production

# المضيفات المسموح بها (AllowedHosts)
# فاصل بينهم بـ فاصلة
ALLOWED_HOSTS=localhost,yourdomain.com,api.yourdomain.com

# ─────────────────────────────────────────────────────────────────
# CORS (Cross-Origin Resource Sharing)
# ─────────────────────────────────────────────────────────────────

# النطاقات المسموح بها للـ CORS (فاصل بـ فاصلة)
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com,http://localhost:3000

# ─────────────────────────────────────────────────────────────────
# السجلات والمراقبة (Logging)
# ─────────────────────────────────────────────────────────────────

# مستوى السجلات: Trace, Debug, Information, Warning, Error, Critical
LOG_LEVEL=Information

# مسار حفظ السجلات (اختياري)
# LOG_PATH=/var/log/sugo-api/

# ─────────────────────────────────────────────────────────────────
# البريد الإلكتروني (Email — للمستقبل)
# ─────────────────────────────────────────────────────────────────

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@yourdomain.com

# ─────────────────────────────────────────────────────────────────
# خدمات خارجية (3rd Party Services)
# ─────────────────────────────────────────────────────────────────

# Azure Application Insights (اختياري)
# APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=...

# ─────────────────────────────────────────────────────────────────
# نصائح الأمان (Security Tips)
# ─────────────────────────────────────────────────────────────────
# 
# ✅ DO:
#   - استخدم كلمات مرور قوية (16+ حرف مع رموز خاصة)
#   - قم بتدوير الـ keys و passwords بانتظام
#   - استخدم https فقط في الإنتاج
#   - احفظ ملف .env في مكان آمن
#   - أضِف .env إلى .gitignore
#   - استخدم secrets management (Azure Key Vault, HashiCorp Vault)
#
# ❌ DON'T:
#   - لا تشارك ملف .env
#   - لا تضع أسرار في الكود
#   - لا تستخدم كلمات مرور بسيطة
#   - لا تاخلطت بين بيئات التطوير والإنتاج
#
# ═════════════════════════════════════════════════════════════════
